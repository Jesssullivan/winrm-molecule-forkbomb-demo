if has use_flake; then
    use flake
fi

dotenv_if_exists

# Activate UV venv if present
if [ -d .venv ]; then
    source .venv/bin/activate
fi

# Ansible configuration
export ANSIBLE_CONFIG="${ANSIBLE_CONFIG:-$(pwd)/ansible/ansible.cfg}"
export ANSIBLE_COLLECTIONS_PATH="${ANSIBLE_COLLECTIONS_PATH:-$(pwd)/ansible/collections}"

# ansible-compat v25 rejects the plural form set by Home Manager
unset ANSIBLE_COLLECTIONS_PATHS 2>/dev/null || true

# macOS fork safety conflicts with Ansible's parallel connection spawning
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# SOPS age key
export SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"

# Add scripts and venv to PATH
PATH_add .venv/bin
PATH_add scripts
